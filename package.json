{
  "name": "hono-inertia-example",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && vite build --mode server",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "start": "node dist/index.js",
    "preview": "$npm_execpath run build && $npm_execpath run start"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@hono/react-renderer": "^1.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@inertiajs/react": "^3.0.3",
    "hono": "^4.12.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.25.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "vite": "^8.0.10",
    "vite-ssr-components": "^0.5.2"
  }
}
